# macOS system files
.DS_Store
**/.DS_Store

# WhisperLiveKit (separate git repo, managed independently)
WhisperLiveKit/

# Session data (dynamically created)
persona/sessions/*
!persona/sessions/.gitkeep
persona/session_index.jsonl
persona/user_responses.jsonl
persona/progress_bank.jsonl
persona/progress.json
persona/.cursor_*.json
persona/memory/*.jsonl

# Shared runtime data
shared/.cursor_*.json
shared/thread.jsonl

# Subagent data (cursors and outputs)
subagent/_cursors/
subagent/single_session/*/data/
subagent/cross_session/*/data/
thread.jsonl

# WebUI build output
bot/webui/dist/
bot/webui/node_modules/

# User notes (dynamically created, should not be committed)
user-notes/
