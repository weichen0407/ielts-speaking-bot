# macOS system files
.DS_Store
**/.DS_Store

# WhisperLiveKit (separate git repo, managed independently)
WhisperLiveKit/

# Session data (dynamically created)
persona/sessions/*
!persona/sessions/.gitkeep
persona/session_index.jsonl
persona/user_responses.jsonl
persona/progress_bank.jsonl
persona/progress.json
persona/.cursor_*.json
persona/memory/*.jsonl
persona/events/thread.jsonl
persona/events/*.tmp
persona/trigger/cron/jobs.json
persona/trigger/cron/.cursor_*.json
persona/trigger/count/.cursor_*.json

# Legacy runtime data
shared/.cursor_*.json
shared/thread.jsonl
session_index.jsonl
user_responses.jsonl
sessions/
monitor/*.jsonl
memory/*.jsonl
trigger/cron/jobs.json
trigger/cron/.cursor_*.json

# Legacy session data (dynamically created)
data/thread.jsonl
data/thread.jsonl.bak-*
*.jsonl.tmp

# Wiki runtime state and derived indexes
persona/wiki/raw/thread/*.jsonl
persona/wiki/state/*.jsonl
persona/wiki/state/ingest_cursor.json
persona/wiki/index/*.sqlite
persona/wiki/index/*.sqlite-*

# Local Python environments and test caches
.venv/
bot/.venv/
.pytest_cache/

# Subagent data (cursors and outputs)
subagent/_cursors/
subagent/single_session/*/data/
subagent/cross_session/*/data/
thread.jsonl

# WebUI build output
bot/webui/dist/
bot/webui/node_modules/

# Python bytecode cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# User notes (dynamically created, should not be committed)
user-notes/

# Local resume draft
cv.tex
cv_en.tex

# Local private notes, interview prep, and scratch documents
.local/
